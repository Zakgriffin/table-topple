// Function call hierarchy for the De Bruijn torus position-tracking pipeline.
//
// Regenerated by hand from src/*.ts after: (1) deleting the retired Option-B
// (corner/mesh/vanishing-point) and Stage-2 (axis-aligned decodeFrame)
// pipelines, wiring the line-based pipeline into main.ts's live render loop
// as the sole position source; and (2) removing the global rotation-
// estimate + autocorrelation-pitch chain (estimateRotationRad/detectGrid)
// entirely, replacing it with src/lattice.ts's estimateLocalSpacing (a
// purely local, self-contained pitch inference) and a fixed Hough bin size
// in main.ts. Import into any Graphviz-based viewer, e.g.:
//   - https://dreampuf.github.io/GraphvizOnline/ (paste directly)
//   - https://edotor.net/ (paste directly)
//   - VS Code "Graphviz Interactive Preview" extension
//   - local: `dot -Tsvg pipeline-call-graph.dot -o pipeline-call-graph.svg`
//
// Each node's second (small) line is a one-sentence description; hovering a
// node in an SVG-rendering viewer shows the same text as a tooltip. Solid
// arrows are direct function calls; dashed arrows are scheduling/event
// relationships (timers, button clicks) rather than a plain call.

digraph PipelineCallGraph {
  rankdir=TB;
  fontname="Helvetica";
  labelloc="t";
  label="De Bruijn Torus Tracker — Pipeline Call Hierarchy";
  fontsize=22;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, margin="0.15,0.1"];
  edge [color="#888888", arrowsize=0.7];

  // ── Setup (runs once, at page load) ──────────────────────────────────────
  subgraph cluster_setup {
    label="Setup — once at load (src/debruijn.ts)";
    style="rounded,filled"; color="#ddd8c4"; fillcolor="#f5f2e6";
    generateTorus [label="generateTorus(order)\n{ builds a random De Bruijn torus pattern big enough that every order×order window is unique }", fillcolor="#efe9d0", tooltip="Builds a random De Bruijn torus pattern of the given order, big enough that every order x order window is unique."];
    buildLookupTable [label="buildLookupTable(torus)\n{ maps every packed bit-window key to its (row,col) }", fillcolor="#efe9d0", tooltip="Builds an Int32Array mapping every packed order x order bit-window key to its (row,col) position on the torus."];
  }

  // ── Camera & render loop ─────────────────────────────────────────────────
  subgraph cluster_camera {
    label="Camera & render loop (src/main.ts)";
    style="rounded,filled"; color="#c9d9e8"; fillcolor="#eaf2f9";
    startCamera [label="startCamera(facing)\n{ requests getUserMedia stream, starts video }", fillcolor="#d7e7f5", tooltip="Requests a camera stream via getUserMedia and starts the video element playing."];
    setupZoomControl [label="setupZoomControl()\n{ wires the zoom slider to hardware zoom, if available }", fillcolor="#d7e7f5", tooltip="Detects hardware zoom capability on the active track and wires the zoom slider to it."];
    render [label="render()\n{ per-frame: draws video + last pipeline result + status }", fillcolor="#bcd6ee", tooltip="Per-frame render loop: draws the live video, overlays the last completed pipeline pass's result, and updates the on-screen position readout."];
  }

  // ── Pipeline orchestration ───────────────────────────────────────────────
  subgraph cluster_orch {
    label="Pipeline orchestration (src/main.ts)";
    style="rounded,filled"; color="#c9d9e8"; fillcolor="#eaf2f9";
    scheduleNextPipelinePass [label="scheduleNextPipelinePass()\n{ re-arms the timer once the previous pass finishes }", fillcolor="#d7e7f5", tooltip="Re-arms a timer (tRefreshDelay ms) to run another pipeline pass once the previous one finishes -- not a fixed-cadence interval."];
    triggerAnalysis [label="triggerAnalysis(after)\n{ paints \"analyzing...\", runs one pass next frame }", fillcolor="#d7e7f5", tooltip="Paints an \"analyzing...\" status, then runs one pipeline pass on the next animation frame (double rAF so the paint is guaranteed visible first)."];
    runPipeline [label="runPipeline()\n{ THE pass: capture -> L1 -> L2 -> L3 -> homography -> decode }", fillcolor="#9fc3e6", tooltip="The main per-pass function: captures a frame, runs Level 1-3 (using a FIXED Hough bin size, not an adaptive/global estimate), fits a homography, samples the grid through it, and decodes the result."];
    sampleFromHomography [label="sampleFromHomography(bin,H,...)\n{ samples one bit per lattice cell via H }", fillcolor="#d7e7f5", tooltip="Samples one bit per lattice cell by mapping (row+0.5, col+0.5) through the fitted homography H into raw pixel space."];
    mirrorRowsGrid [label="mirrorRowsGrid(sg)\n{ row-reversed copy, for the row-mirror ambiguity }", fillcolor="#d7e7f5", tooltip="Returns a copy of a sampled grid with its rows reversed, covering the row-axis sort-direction ambiguity indexFamilyLines leaves unresolved."];
    rawToVideo [label="rawToVideo(rx,ry,d)\n{ raw analysis buffer -> live video canvas coords }", fillcolor="#d7e7f5", tooltip="Maps a point in the analysis-resolution raw buffer back to live video canvas coordinates, for overlay drawing."];
    drawDebugOverlays [label="drawDebugOverlays(d)\n{ draws whichever debug layers are toggled on }", fillcolor="#d7e7f5", tooltip="Draws whichever of the pipeline's diagnostic layers are toggled on (binarized, hough lines, VPs, rectified grid, patches) from the last completed pass."];
  }

  // ── Level 1 ───────────────────────────────────────────────────────────────
  subgraph cluster_l1 {
    label="Level 1 — Hough lines (src/lines.ts)";
    style="rounded,filled"; color="#cfe3c8"; fillcolor="#e9f4e4";
    buildLineAccumulator [label="buildLineAccumulator(gray,...)\n{ gradient-oriented Hough transform }", fillcolor="#cde8c3", tooltip="Gradient-oriented Hough transform: each edge pixel casts exactly one weighted (theta,rho) vote using its own gradient angle, instead of a full angle sweep. Called with a FIXED bin size (main.ts's HOUGH_RHO_BIN_PX) -- no lines exist yet at this point to measure a local pitch from."];
    lines_boxBlur [label="boxBlur(src,radius)\n{ simple box blur for stabler gradients }", fillcolor="#d9edd1", tooltip="Simple box blur applied before computing gradients, to stabilize edge orientation against pixel-grid aliasing."];
    findLinePeaks [label="findLinePeaks(field,...)\n{ NMS + sub-bin centroid refinement }", fillcolor="#cde8c3", tooltip="Non-max suppression over the (theta,rho) accumulator, then sub-bin weighted-centroid refinement, returning the final candidate lines."];
  }

  // ── Level 2 ───────────────────────────────────────────────────────────────
  subgraph cluster_l2 {
    label="Level 2 — VP split (src/vp.ts)";
    style="rounded,filled"; color="#f0d9b0"; fillcolor="#fbeed8";
    estimateVanishingPoint [label="estimateVanishingPoint(lines)\n{ weighted-LS common point via smallest eigenvector }", fillcolor="#f7e2b8", tooltip="Finds the weighted-least-squares common point of a set of lines by taking the smallest eigenvector of their combined outer-product matrix."];
    toAbsoluteLine [label="toAbsoluteLine(line,cx,cy)\n{ center-relative (theta,rho) -> absolute (a,b,c) }", fillcolor="#f7e2b8", tooltip="Converts a center-relative (theta,rho) line into an absolute-coordinate line equation a*X + b*Y + c = 0."];
    lineResidualPx [label="lineResidualPx(line,vp,...)\n{ pixel distance from a line to a candidate VP }", fillcolor="#f7e2b8", tooltip="Perpendicular pixel distance from a line to a hypothesized vanishing point (or an angular-equivalent distance if the VP is at/near infinity)."];
    crossLines [label="crossLines(l1,l2)\n{ homogeneous cross product = intersection point }", fillcolor="#f7e2b8", tooltip="Intersects two absolute-coordinate lines via the homogeneous cross product; gives a point-at-infinity for free if the lines are parallel."];
    splitIntoTwoFamilies [label="splitIntoTwoFamilies(lines,...)\n{ RANSAC split into row/col families by shared VP }", fillcolor="#f2c98a", tooltip="RANSAC-style exhaustive pairwise hypothesis search that splits a mixed set of lines into the two families sharing a vanishing point."];
    vpToPoint [label="vpToPoint(vp) / vpIsFinite(vp)\n{ homogeneous -> Cartesian / finiteness check }", fillcolor="#f7e2b8", tooltip="Trivial helpers: vpToPoint divides through by w for Cartesian coords; vpIsFinite checks whether w is far enough from 0 to be a real point."];
  }

  // ── Level 3 ───────────────────────────────────────────────────────────────
  subgraph cluster_l3 {
    label="Level 3 — index recovery (src/lattice.ts)";
    style="rounded,filled"; color="#e3c6dd"; fillcolor="#f6e9f3";
    indexFamilyLines [label="indexFamilyLines(family,otherVp,...)\n{ sorts along a transversal, then recovers indices }", fillcolor="#eed4e8", tooltip="Sorts a family's lines along a fixed transversal (through the OTHER family's vanishing point) and recovers each line's true gap-tolerant integer index."];
    recoverIndicesFromTransversal [label="recoverIndicesFromTransversal(scored,...)\n{ RANSAC over seed windows + gap-size guesses }", fillcolor="#e5b9dc", tooltip="RANSAC-style search over small seed windows and candidate gap sizes, fitting and scoring Mobius models to find the best gap-tolerant index assignment."];
    estimateLocalSpacing [label="estimateLocalSpacing(scored,start,...)\n{ NEW: local pitch from real neighboring gaps }", fillcolor="#d99bce", tooltip="Measures the true LOCAL pitch near a candidate window from the family's own real neighboring detections (minimum of a few nearby adjacent-line gaps) -- replaces an earlier GLOBAL apparent-pitch estimate that was systematically wrong under perspective away from wherever it was measured."];
    fitMobius [label="fitMobius(pairs)\n{ fits a 1D projective transform via smallest eigenvector }", fillcolor="#eed4e8", tooltip="Fits a Mobius (1D projective) transform t=(pv+q)/(rv+s) from (index,position) pairs via the same smallest-eigenvector approach as the homography/VP fits."];
    applyMobius [label="applyMobius / invertMobius\n{ evaluate the fit forward / backward }", fillcolor="#eed4e8", tooltip="applyMobius evaluates index->position; invertMobius solves position->index for a fitted Mobius model."];
    buildLatticeCorrespondences [label="buildLatticeCorrespondences(rows,cols,...)\n{ every row x col crossing -> a homography correspondence }", fillcolor="#eed4e8", tooltip="Turns every (row-line, col-line) crossing into a PointCorrespondence with a known relative integer (row,col) address, for fitHomographyDLT."];
  }

  // ── Homography ────────────────────────────────────────────────────────────
  subgraph cluster_homog {
    label="Homography fit & apply (src/homography.ts)";
    style="rounded,filled"; color="#e8c9c2"; fillcolor="#faeae7";
    fitHomographyDLT [label="fitHomographyDLT(correspondences)\n{ normalized DLT + normal-equations solve }", fillcolor="#f3b9ac", tooltip="Fits a homography H (lattice (u,v) -> image (x,y)) from >= 4 point correspondences via DLT with Hartley normalization."];
    normalize [label="normalize(pts)\n{ Hartley normalization: center + scale to avg sqrt(2) }", fillcolor="#f6d9d1", tooltip="Hartley normalization (translate to centroid, scale so average distance from origin is sqrt(2)) -- a numerically-stable-DLT prerequisite."];
    solveLinearSystem [label="solveLinearSystem(A,b)\n{ Gaussian elimination with partial pivoting }", fillcolor="#f6d9d1", tooltip="Solves the general linear system Ax=b via Gaussian elimination with partial pivoting; used for the 8x8 DLT normal-equations solve."];
    mat3Ops [label="mat3Multiply / mat3Invert\n{ basic 3x3 matrix ops }", fillcolor="#f6d9d1", tooltip="Basic row-major 3x3 matrix multiply and closed-form inverse, used to denormalize the DLT fit."];
    applyHomography [label="applyHomography(H,u,v)\n{ projects a lattice point through H }", fillcolor="#f3b9ac", tooltip="Projects a lattice (u,v) point through homography H into image pixel coordinates."];
    invertHomography [label="invertHomography(H)\n{ returns H's inverse matrix }", fillcolor="#f3b9ac", tooltip="Returns the inverse of a fitted homography matrix."];
    applyMat3 [label="applyMat3(H,x,y)\n{ internal: homogeneous matrix-vector apply }", fillcolor="#f6d9d1", tooltip="Internal homogeneous matrix-vector application shared by applyHomography's implementation."];
  }

  // ── Shared decode primitives ─────────────────────────────────────────────
  subgraph cluster_decode {
    label="Shared grid/decode primitives (src/decode.ts)";
    style="rounded,filled"; color="#d7cdEE"; fillcolor="#efeaf9";
    toGrayscale [label="toGrayscale(rgba)\n{ RGBA -> luma }", fillcolor="#e3dbf5", tooltip="Converts an RGBA buffer to grayscale via the standard luma weighting."];
    binarize [label="binarize(gray)\n{ global mean threshold -> black/white }", fillcolor="#e3dbf5", tooltip="Binarizes a grayscale buffer via a global mean threshold (dark -> 1, a black cell)."];
    pickBestCandidate [label="pickBestCandidate(grids,...)\n{ tiles, seeds anchors, scores by correlation }", fillcolor="#c9b8ec", tooltip="Tiles each candidate sampled grid into patches, generates exact-match + sliding-window seed anchors, and scores every one by correlating the WHOLE grid against the real pattern."];
    buildTiles [label="buildTiles(sg,order)\n{ splits a grid into non-overlapping order x order tiles }", fillcolor="#e3dbf5", tooltip="Splits a sampled grid into non-overlapping order x order tiles for exact-match lookup."];
    patchesForOrientation [label="patchesForOrientation(tiles,...)\n{ packs + exact-match-looks-up each tile }", fillcolor="#e3dbf5", tooltip="Packs each tile's bits under one reading orientation and looks up an exact-match seed anchor from the lookup table."];
    packPatchCells [label="packPatchCells(cells,order,orientation)\n{ packs a cell block into a lookup key }", fillcolor="#e9e2f7", tooltip="Packs an order x order cell block into a lookup key, reading it under one of the 4 rotation orientations."];
    findSlidingSeeds [label="findSlidingSeeds(sg,...)\n{ exhaustive sliding-window seed search }", fillcolor="#e3dbf5", tooltip="Alternative seed generation for grids with edge gaps: slides an order x order window across EVERY position, not just tile-aligned ones."];
    scoreCorrelation [label="scoreCorrelation(sg,torus,...)\n{ scores an anchor by correlating the whole grid }", fillcolor="#e3dbf5", tooltip="Scores a candidate torus anchor by comparing every sampled cell (not just one patch) against the actual known pattern at the position it implies."];
    rotateShift [label="rotateShift(da,db,orientation)\n{ rotates a shift vector to match reading orientation }", fillcolor="#e9e2f7", tooltip="Applies the same orientation-dependent rotation packPatchCells uses, but to a (row shift, col shift) vector instead of a cell index."];
  }

  // ── Shared linear algebra ────────────────────────────────────────────────
  subgraph cluster_linalg {
    label="Shared linear algebra (src/linalg.ts)";
    style="rounded,filled"; color="#cddbe0"; fillcolor="#e8f1f3";
    smallestEigenvector [label="smallestEigenvector(M)\n{ eigenvector of the SMALLEST eigenvalue }", fillcolor="#d5e6ea", tooltip="Returns the eigenvector of a symmetric matrix's smallest eigenvalue -- the least-squares null space of a set of homogeneous linear constraints."];
    jacobiEigenSymmetric [label="jacobiEigenSymmetric(A)\n{ classic cyclic Jacobi eigenvalue algorithm }", fillcolor="#dcebEE", tooltip="Classic cyclic Jacobi eigenvalue algorithm for small (3x3/4x4) symmetric matrices."];
  }

  // ── Edges: startup ────────────────────────────────────────────────────────
  generateTorus -> buildLookupTable;

  // ── Edges: camera / render entry points ─────────────────────────────────
  startCamera -> setupZoomControl;
  startCamera -> render [style=dashed, label="  .then()", fontsize=9];
  render -> render [style=dashed, label="  requestAnimationFrame", fontsize=9];
  render -> drawDebugOverlays;

  // ── Edges: pipeline scheduling ───────────────────────────────────────────
  scheduleNextPipelinePass -> triggerAnalysis [style=dashed, label="  setTimeout", fontsize=9];
  triggerAnalysis -> runPipeline;
  triggerAnalysis -> scheduleNextPipelinePass [style=dashed, label="  after()", fontsize=9];

  // ── Edges: runPipeline (Level 1 -> 2 -> 3 -> homography -> decode) ──────
  runPipeline -> toGrayscale;
  runPipeline -> binarize;
  runPipeline -> buildLineAccumulator;
  runPipeline -> findLinePeaks;
  runPipeline -> splitIntoTwoFamilies;
  runPipeline -> indexFamilyLines;
  runPipeline -> buildLatticeCorrespondences;
  runPipeline -> fitHomographyDLT;
  runPipeline -> sampleFromHomography;
  runPipeline -> mirrorRowsGrid;
  runPipeline -> pickBestCandidate;
  sampleFromHomography -> applyHomography;

  drawDebugOverlays -> rawToVideo;
  drawDebugOverlays -> vpToPoint;
  drawDebugOverlays -> applyHomography;

  // ── Edges: Level 1 internals ─────────────────────────────────────────────
  buildLineAccumulator -> lines_boxBlur;

  // ── Edges: Level 2 internals ─────────────────────────────────────────────
  estimateVanishingPoint -> toAbsoluteLine;
  estimateVanishingPoint -> smallestEigenvector;
  lineResidualPx -> toAbsoluteLine;
  splitIntoTwoFamilies -> toAbsoluteLine;
  splitIntoTwoFamilies -> crossLines;
  splitIntoTwoFamilies -> lineResidualPx;
  splitIntoTwoFamilies -> estimateVanishingPoint;

  // ── Edges: Level 3 internals ─────────────────────────────────────────────
  indexFamilyLines -> vpIsFinite;
  indexFamilyLines -> vpToPoint;
  indexFamilyLines -> toAbsoluteLine;
  indexFamilyLines -> crossLines;
  indexFamilyLines -> recoverIndicesFromTransversal;
  recoverIndicesFromTransversal -> fitMobius;
  recoverIndicesFromTransversal -> applyMobius;
  recoverIndicesFromTransversal -> estimateLocalSpacing;
  fitMobius -> smallestEigenvector;
  buildLatticeCorrespondences -> toAbsoluteLine;
  buildLatticeCorrespondences -> crossLines;

  // ── Edges: homography internals ──────────────────────────────────────────
  fitHomographyDLT -> normalize;
  fitHomographyDLT -> solveLinearSystem;
  fitHomographyDLT -> mat3Ops;
  applyHomography -> applyMat3;
  invertHomography -> mat3Ops;

  // ── Edges: decode internals ───────────────────────────────────────────────
  pickBestCandidate -> buildTiles;
  pickBestCandidate -> patchesForOrientation;
  pickBestCandidate -> rotateShift;
  pickBestCandidate -> scoreCorrelation;
  pickBestCandidate -> findSlidingSeeds;
  patchesForOrientation -> packPatchCells;
  findSlidingSeeds -> packPatchCells;
  findSlidingSeeds -> rotateShift;
  scoreCorrelation -> rotateShift;

  // ── Edges: linalg internals ───────────────────────────────────────────────
  smallestEigenvector -> jacobiEigenSymmetric;

  // ── Legend ────────────────────────────────────────────────────────────────
  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; color="#cccccc"; fillcolor="#f7f7f7"; fontsize=10;
    legend_call [label="solid arrow = direct function call", shape=plaintext, fillcolor="none"];
    legend_sched [label="dashed arrow = scheduling / event (timer, rAF, promise)", shape=plaintext, fillcolor="none"];
    legend_new [label="pink/magenta node = new since last graph (estimateLocalSpacing)", shape=plaintext, fillcolor="none"];
  }
}
